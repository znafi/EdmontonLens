# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GCP_PROJECT_ID=your-project-id
BIGQUERY_DATASET=edmonton_lens

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# Local DB (dev)
DATABASE_URL=postgresql://postgres:password@localhost:5432/edmonton_lens

# Edmonton Open Data
EDMONTON_OPEN_DATA_APP_TOKEN=your-socrata-app-token

# MySQL (local dev)
MYSQL_DATABASE_URL=mysql+pymysql://edmonton:password@localhost:3306/edmonton_lens

# SQL Server (local dev)
SQLSERVER_DATABASE_URL=mssql+pyodbc://sa:EdmontonLens123!@localhost:1433/edmonton_lens?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
